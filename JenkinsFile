pipeline {
    agent any
    stages {
        stage('Go Build') {
            agent { docker { image 'golang:1.23-alpine' } }
            steps {
                sh 'go mod download'
                sh 'go build -o gorentcar ./main.go'
            }
        }
        stage('Go Test') {
            agent { docker { image 'golang:1.22-alpine' } }
            steps {
                sh 'go test ./... -v'
            }
        }
    }
}
EOF